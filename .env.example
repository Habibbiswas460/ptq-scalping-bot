# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    PTQ SCALPING BOT - CONFIGURATION                          ║
# ║                     Copy this to .env and fill values                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# 🔐 BROKER CREDENTIALS (Get from Angel One)
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_password
ANGEL_API_KEY=your_api_key
ANGEL_TOTP_SECRET=your_totp_secret

# 💰 TRADING MODE
PAPER_TRADING=true
USE_LIVE_DATA=false
TEST_MODE=false

# 💵 CAPITAL SETTINGS
TOTAL_CAPITAL=30000
RISK_PER_TRADE_PCT=1.5
MAX_DAILY_LOSS=1500

# 📊 POSITION SIZING
CE_QUANTITY=65
PE_QUANTITY=65

# 🛑 STOP LOSS / TAKE PROFIT
SL_POINTS=6
TP_POINTS=12

# 📈 TRAILING STOP LOSS
TSL_ENABLED=true
TSL_LEVELS=8:4,12:7,16:11,20:15,25:20,30:25,40:35,50:45

# 📊 STRATEGY SCORING
MIN_SCORE=5
MIN_CONFIDENCE=70

# ⏱️ TRADING LIMITS
MAX_TRADES_PER_DAY=15
MAX_TRADES_PER_HOUR=10

# 🚨 KILL SWITCH
KILL_SWITCH_ENABLED=true
KILL_SWITCH_LOSS=450

# ⏰ MARKET HOURS
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
TRADING_START=09:20
TRADING_END=15:10

# 📱 TELEGRAM (Optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# 🖥️ DASHBOARD
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
